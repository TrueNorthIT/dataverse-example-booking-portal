# Dataverse Contact API — the running deployment this app talks to
VITE_API_BASE_URL=https://your-contact-api.example.com/api/v2/citizenbooking

# Auth0 SPA application (citizen sign-in)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-spa-client-id
VITE_AUTH0_AUDIENCE=https://your-api-audience/citizenbooking

# Azure Web PubSub (optional — live presence). Leave the key blank to disable
# presence. SECURITY: never put a real key here for a public deployment; mint
# the client-access token from a backend instead (see src/contexts/PresenceContext.tsx).
VITE_WEBPUBSUB_URL=https://your-namespace.webpubsub.azure.com
VITE_WEBPUBSUB_KEY=

# Demo data provisioning only (npm run schema|seed|clean) — service principal
# with access to your Dataverse environment. Used by scripts/, never by the app.
VITE_TENANT_ID=your-azure-tenant-id
VITE_CLIENT_ID=your-app-registration-client-id
VITE_DATAVERSE_URL=https://your-org.crm.dynamics.com
CLIENT_SECRET=

# Playwright E2E credentials (an Auth0 test user)
AUTH0_TEST_EMAIL=
AUTH0_TEST_PASSWORD=
